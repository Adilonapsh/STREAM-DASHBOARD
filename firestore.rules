rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Help validation functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidUserCredentials(data) {
      return data.keys().hasAll(['userId', 'discordUserId', 'deckId', 'tiptapPrivateKey', 'tiptapAlertWidgetId'])
        && data.keys().size() <= 7
        && data.userId is string && data.userId.size() <= 128
        && data.discordUserId is string && data.discordUserId.size() <= 128
        && data.deckId is string && data.deckId.size() <= 256
        && data.tiptapPrivateKey is string && data.tiptapPrivateKey.size() <= 256
        && data.tiptapAlertWidgetId is string && data.tiptapAlertWidgetId.size() <= 128;
    }

    match /user_credentials/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserCredentials(incoming()) && incoming().userId == userId;
      allow update: if isOwner(userId) && isValidUserCredentials(incoming()) && incoming().userId == userId 
        && incoming().userId == resource.data.userId;
      allow delete: if false;
    }
  }
}
